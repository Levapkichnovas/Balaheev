# ============================================================
#  Серверная конфигурация (Apache) — burim03.ru
# ============================================================

# Страница ошибки 404
ErrorDocument 404 /404.html

# ── БЕЗОПАСНОСТЬ (HTTP-заголовки) ─────────────────────────
# HSTS не дублируем — reg.ru отдаёт Strict-Transport-Security сам
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; img-src 'self' data:; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; frame-src 'none'; object-src 'none';"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>

# ── HTTPS РЕДИРЕКТ ────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── .well-known (Let's Encrypt ACME) ──────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule "^\.well-known/" - [L]
</IfModule>

# ── БЛОКИРОВКА ДОСТУПА К СКРЫТЫМ ФАЙЛАМ ───────────────────
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── БЛОКИРОВКА СЛУЖЕБНЫХ РАСШИРЕНИЙ ───────────────────────
<FilesMatch "\.(log|bak|sql|ini|sh|env|yml|yaml|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── send.php: только POST, без индексации, без кэша ───────
<Files "send.php">
    <LimitExcept POST>
        Order allow,deny
        Deny from all
    </LimitExcept>
    <IfModule mod_headers.c>
        Header always set X-Robots-Tag "noindex, nofollow"
        Header always set Cache-Control "no-store, no-cache, must-revalidate"
    </IfModule>
</Files>

# ── ЗАЩИТА ОТ HOTLINKING ──────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$ [NC]
    RewriteCond %{HTTP_REFERER} !^https?://%{HTTP_HOST} [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]
</IfModule>

# ── БЛОКИРОВКА ВРЕДОНОСНЫХ UA ─────────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (HTTrack|WebCopier|WebZIP|Teleport|SiteSnagger|wget|libwww) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── ЗАПРЕТ ЛИСТИНГА ДИРЕКТОРИЙ ────────────────────────────
Options -Indexes

# ── СЖАТИЕ (GZIP) ────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── КЭШ СТАТИКИ ───────────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(woff2|woff|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive on
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── КОДИРОВКА ────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── СКРЫТИЕ ВЕРСИИ СЕРВЕРА ───────────────────────────────
ServerSignature Off
